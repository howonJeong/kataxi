# 1. 의존성 (가장 중요: 서버에서 직접 npm install 해야 함)
node_modules/
package-lock.json

# 2. 데이터베이스 (내 로컬 DB가 서버로 올라가서 덮어씌워지는 것 방지)
*.db
*.sqlite
*.sqlite3

# 3. 운영체제 관련 쓰레기 파일 (맥북 전용)
.DS_Store
Thumbs.db

# 4. 환경 변수 및 보안 키
.env
*.pem
credentials/

# 5. 로그 및 빌드 파일
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pm2/
logs/